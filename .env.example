# Optional: deploy google-apps-script/Code.gs and add its URL here to also save
# every enquiry to Google Sheets. Without this variable, submissions are emailed
# directly to sidramareddy432@gmail.com through the built-in form endpoint.
VITE_LEAD_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Optional for the Vercel API route. Use the same Google Apps Script URL here
# so /api/lead can send reliably from local dev and production.
LEAD_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
