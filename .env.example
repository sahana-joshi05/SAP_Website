# Backend mail API settings for /api/lead.
# For Gmail, enable 2-Step Verification and create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=svcuriotech@gmail.com
SMTP_PASS=your-16-character-app-password

# Optional display sender. Keep the email the same as SMTP_USER for best delivery.
MAIL_FROM="SV CurioTech <svcuriotech@gmail.com>"

# Admissions lead recipients.
LEAD_TO_EMAIL=svcuriotech@gmail.com
LEAD_CC_EMAIL=

# Optional: only use this if the API is hosted somewhere other than this website.
# VITE_LEAD_API_URL=https://your-domain.com/api/lead
